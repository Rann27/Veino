# VeiNovel Maintenance Mode
# Rename this file to ".htaccess" (replace the production one) to activate.
# Admin (/admin/*), auth, and API remain accessible for recovery work.
# To deactivate: restore .htaccess-production as .htaccess

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Preserve Authorization header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ── NORMAL LARAVEL ROUTING (trailing slash removal, always first) ────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ── MAINTENANCE REDIRECT ─────────────────────────────────────────────
    # Redirect to maintenance page UNLESS the path is in the allow list.
    # All conditions must be true (AND logic) for the redirect to fire.
    RewriteCond %{REQUEST_URI} !^/maintenance\.html$
    RewriteCond %{REQUEST_URI} !^/admin
    RewriteCond %{REQUEST_URI} !^/auth$
    RewriteCond %{REQUEST_URI} !^/login
    RewriteCond %{REQUEST_URI} !^/logout
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/sanctum/
    RewriteCond %{REQUEST_URI} !^/favicon
    RewriteCond %{REQUEST_URI} !^/images/
    RewriteCond %{REQUEST_URI} !^/build/
    RewriteCond %{REQUEST_URI} !^/storage/
    RewriteRule ^(.*)$ /maintenance.html [R=503,L]

    # ── LARAVEL ROUTING (runs for all paths that passed the check above) ─
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>

# Maintenance status headers
<IfModule mod_headers.c>
    Header always set Retry-After "900"
    Header always set X-Maintenance-Mode "active"
    Header always set X-Content-Type-Options nosniff

    <FilesMatch "maintenance\.html$">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </FilesMatch>
</IfModule>

ErrorDocument 503 /maintenance.html

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
