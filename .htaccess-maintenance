# VeiNovel Maintenance Mode
# Rename this file to ".htaccess" (replace the production one) to activate.
# Admin (/admin/*), auth, and API remain accessible for recovery work.
# To deactivate: restore .htaccess-production as .htaccess

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Preserve Authorization header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ── MAINTENANCE REDIRECT ─────────────────────────────────────────────
    # Block all public traffic EXCEPT the paths listed below.

    # Always allow maintenance.html itself
    RewriteCond %{REQUEST_URI} ^/maintenance\.html$ [OR]
    # Allow admin panel and all sub-paths
    RewriteCond %{REQUEST_URI} ^/admin [OR]
    # Allow auth / login / logout
    RewriteCond %{REQUEST_URI} ^/auth$ [OR]
    RewriteCond %{REQUEST_URI} ^/login [OR]
    RewriteCond %{REQUEST_URI} ^/logout [OR]
    # Allow API & Sanctum (Inertia, session, CSRF)
    RewriteCond %{REQUEST_URI} ^/api/ [OR]
    RewriteCond %{REQUEST_URI} ^/sanctum/ [OR]
    # Allow static assets
    RewriteCond %{REQUEST_URI} ^/favicon [OR]
    RewriteCond %{REQUEST_URI} ^/images/ [OR]
    RewriteCond %{REQUEST_URI} ^/build/ [OR]
    RewriteCond %{REQUEST_URI} ^/storage/
    RewriteRule ^ - [L]

    # Everything else → maintenance page
    RewriteRule ^(.*)$ /maintenance.html [R=503,L]

    # ── NORMAL LARAVEL ROUTING (for allowed paths) ───────────────────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>

# Maintenance status headers
<IfModule mod_headers.c>
    Header always set Retry-After "900"
    Header always set X-Maintenance-Mode "active"
    Header always set X-Content-Type-Options nosniff

    <FilesMatch "maintenance\.html$">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </FilesMatch>
</IfModule>

ErrorDocument 503 /maintenance.html

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
